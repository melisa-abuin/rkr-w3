{
  "name": "rkr-w3",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "dev:admin": "turbo dev --filter=admin",
    "format": "prettier --write .",
    "lint": "turbo lint",
    "prepare": "husky",
    "start": "turbo start",
    "test": "turbo test",
    "typecheck": "turbo typecheck"
  },
  "resolutions": {
    "postcss": "8.4.31",
    "js-yaml": "^3.13.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "prettier-eslint": "^17.1.1",
    "turbo": "^2.10.5"
  }
}
